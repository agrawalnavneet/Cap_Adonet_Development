@model IEnumerable<Project9.Models.Student>

<h2>Students List</h2>

<p>
    <a asp-action="Create" class="btn btn-success">Add Student</a>
</p>

<table class="table table-bordered table-striped">

    <thead>
        <tr>
            <th>Student ID</th>
            <th>Name</th>
            <th>Email</th>
            <th>Age</th>
            <th>Marks</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>
                <td>@item.StudentId</td>
                <td>@item.Name</td>
                <td>@item.Email</td>
                <td>@item.Age</td>
                <td>@item.Marks</td>

                <td>
                    <a asp-action="Edit" asp-route-id="@item.StudentId" class="btn btn-warning">
                        Edit
                    </a>

                    <a asp-action="Delete" asp-route-id="@item.StudentId" class="btn btn-danger">
                        Delete
                    </a>
                </td>
            </tr>
        }

    </tbody>

</table>